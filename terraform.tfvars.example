# vCenter connection — set password via environment variable:
#   export TF_VAR_vsphere_password="..."
vsphere_server = "vcenter.example.com"
vsphere_user   = "administrator@vsphere.local"

# Infrastructure placement
datacenter = "dc01"
cluster    = "cluster01"
datastore  = "datastore01"

# VM identity
vm_name   = "linux-vm-01"
vm_folder = "VMs/Linux"

# Template
template_name = "ubuntu-22.04-template"

# Compute
num_cpus = 2
memory   = 4096

# Storage
disks = [
  {
    label       = "disk0"
    size        = 50
    unit_number = 0
  }
]

# Networking
network_interfaces = [{ network_name = "VM Network" }]

# Static IP — remove ip_settings block entirely for DHCP
ip_settings     = [{ ipv4_address = "192.168.1.100", ipv4_netmask = 24 }]
ipv4_gateway    = "192.168.1.1"
dns_servers     = ["192.168.1.10", "192.168.1.11"]
dns_suffix_list = ["example.com"]

# Guest OS
guest_id  = "ubuntu64Guest"   # ubuntu64Guest, rhel9_64Guest, debian12_64Guest, etc.
time_zone = "UTC"              # IANA timezone string e.g. America/New_York

# Hardware
firmware = "bios"
